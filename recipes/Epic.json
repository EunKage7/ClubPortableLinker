    { "Name": "Epic ProgramData", "Source": "%ProgramData%\\Epic", "Target": "{portableRoot}\\ProgramData\\Epic", "Kind": "Junction", "MoveExisting": true, "OverwriteEmptySource": true, "ExistingSourceAction": "MoveToTargetOrBackup" },
